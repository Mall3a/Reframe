        %tmp.39 = dup %tmp.27;
        %tmp.40 = aputv %tmp.39 2 %tmp.38;
        %tmp.41 = newd 2;
        %tmp.43 = const :text;
        symbol [ text %tmp.43 96 14 18 const ];
        %tmp.44 = "Como otros me tratan es su historia, no la mía ni Mi valor.";
