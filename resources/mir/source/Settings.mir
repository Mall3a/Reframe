        %tmp.52 = dup %tmp.40;
        %tmp.53 = aputv %tmp.52 3 %tmp.51;
        %tmp.54 = newd 2;
        %tmp.56 = const :text;
        symbol [ text %tmp.56 97 14 18 const ];
        %tmp.57 = "Nadie te conoce tanto como Yo; no aceptes juicios ajenos como verdades.";
